{
  "info": {
    "name": "FIT4110 Lab05 Analytics",
    "_postman_id": "lab05-analytics-collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function() { pm.response.to.have.status(200); });",
              "pm.test('Service ok', function() { var json = pm.response.json(); pm.expect(json.status).to.eql('ok'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Summary",
      "request": {
        "method": "GET",
        "header": [{"key": "Authorization", "value": "Bearer {{authToken}}"}],
        "url": "{{baseUrl}}/analytics/summary"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function() { pm.response.to.have.status(200); });",
              "pm.test('Has totalReadings', function() { var json = pm.response.json(); pm.expect(json).to.have.property('totalReadings'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Events",
      "request": {
        "method": "GET",
        "header": [{"key": "Authorization", "value": "Bearer {{authToken}}"}],
        "url": "{{baseUrl}}/analytics/events"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function() { pm.response.to.have.status(200); });",
              "pm.test('Has items', function() { var json = pm.response.json(); pm.expect(json).to.have.property('items'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Alerts",
      "request": {
        "method": "GET",
        "header": [{"key": "Authorization", "value": "Bearer {{authToken}}"}],
        "url": "{{baseUrl}}/analytics/alerts"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function() { pm.response.to.have.status(200); });",
              "pm.test('Has items', function() { var json = pm.response.json(); pm.expect(json).to.have.property('items'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Unauthorized - No Token",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/analytics/summary"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 401', function() { pm.response.to.have.status(401); });"
            ]
          }
        }
      ]
    }
  ]
}